-- ======================================
-- 🌈 RAINBOW FUNCTION
-- ======================================
local function rainbowColor()
    local time = tick() * 3
    return Color3.new(math.sin(time), math.sin(time + 2), math.sin(time + 4))
end

-- ======================================
-- 💀 GET CLOSEST PLAYER
-- ======================================
local function GetClosestPlayer()
    local ClosestDistance = math.huge
    local ClosestPlayer = nil
    
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") and Player.Character.Humanoid.Health > 0 then
                local Character = Player.Character
                local RootPart = Character.HumanoidRootPart
                
                local RaycastParams = RaycastParams.new()
                RaycastParams.FilterDescendantsInstances = {LocalPlayer.Character, Character}
                RaycastParams.FilterType = Enum.RaycastFilterType.Exclude
                
                local RaycastResult = workspace:Raycast(Camera.CFrame.Position, RootPart.Position - Camera.CFrame.Position, RaycastParams)
                
                if not RaycastResult then
                    local Distance = (Camera.CFrame.Position - RootPart.Position).Magnitude
                    if Distance < ClosestDistance and Distance <= FOVRadius then
                        ClosestDistance = Distance
                        ClosestPlayer = Player
                    end
                end
            end
        end
    end
    return ClosestPlayer
end

-- ======================================
-- 🕷️ MAIN LOOP
-- ======================================
local HighlightObjects = {}
local LastShot = 0

RunService.Heartbeat:Connect(function()
    
    -- ======================================
    -- 🌈 ESP LOGIC
    -- ======================================
    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            if Player.Character and Player.Character:FindFirstChild("Humanoid") and Player.Character.Humanoid.Health > 0 then
                local Character = Player.Character
                
                -- CREATE
                if not HighlightObjects[Player.UserId] and ESPEnabled then
                    local highlight = Instance.new("Highlight")
                    highlight.Name = "Outline"
                    highlight.Parent = Character
                    highlight.Adornee = Character
                    highlight.FillTransparency = 1
                    highlight.OutlineTransparency = 0
                    HighlightObjects[Player.UserId] = highlight
                end
                
                -- UPDATE COLOR
                if HighlightObjects[Player.UserId] then
                    HighlightObjects[Player.UserId].OutlineColor = rainbowColor()
                end
            else
                -- REMOVE IF DEAD
                if HighlightObjects[Player.UserId] then
                    HighlightObjects[Player.UserId]:Destroy()
                    HighlightObjects[Player.UserId] = nil
                end
            end
        end
    end
    
    -- ======================================
    -- 💀 AIMBOT LOGIC
    -- ======================================
    if AimbotEnabled then
        local Target = GetClosestPlayer()
        if Target and Target.Character then
            local Character = Target.Character
            local AimPart
            
            if AimAtHead then
                AimPart = Character:FindFirstChild("Head") or Character.HumanoidRootPart
            else
                AimPart = Character.HumanoidRootPart
            end
            
            local Velocity = Vector3.new()
            if Character.HumanoidRootPart:FindFirstChild("Velocity") then
                Velocity = Character.HumanoidRootPart.Velocity
            end
            
            local PredictedPos = AimPart.Position + (Velocity * Prediction * 2)
            
            local CurrentCFrame = Camera.CFrame
            local LookAt = CFrame.lookAt(CurrentCFrame.Position, PredictedPos)
            
            local SmoothCFrame = CurrentCFrame:Lerp(LookAt, Smoothness)
            local FinalCFrame = SmoothCFrame:Lerp(LookAt, SnapStrength)
            
            Camera.CFrame = FinalCFrame
            
            -- ======================================
            -- 🔫 AUTO SHOOT
            -- ======================================
            if AutoShootEnabled then
                local CurrentTime = tick()
                if CurrentTime - LastShot > 0.1 then
                    pcall(function()
                        local Tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                        if Tool then
                            Tool:Activate()
                            if Tool:FindFirstChild("RemoteEvent") then Tool.RemoteEvent:FireServer() end
                        end
                    end)
                    LastShot = CurrentTime
                end
            end
        end
    end
end)

